    <script>
    var toopen = [];

    var map = L.map("image-map", {
        tap: false,
        minZoom: 1,
        maxZoom: 4,
        center: [0, 0],
        zoom: 1,
        crs: L.CRS.Simple,
    });

    var w = 3695,
    h = 1288,
    url1 = "/images/dip.png",
    url2 = "/images/dipdark.png",
    url3 = "/images/dippink.png",
    url4 = "/images/dipgreen.png",
    url5 = "/images/dipred.png";

    var southWest = map.unproject([0, h], map.getMaxZoom() - 1);
    var northEast = map.unproject([w, 0], map.getMaxZoom() - 1);
    var bounds = new L.LatLngBounds(southWest, northEast);

    var o1 = L.imageOverlay(url1, bounds);
    var o2 = L.imageOverlay(url2, bounds);
    var o3 = L.imageOverlay(url3, bounds);
    var o4 = L.imageOverlay(url4, bounds);
    var o5 = L.imageOverlay(url5, bounds);

    var overlays = {
        "Light mode": o1,
        "Dark mode": o2,
        "Pink mode": o3,
        "Green mode": o4,
        "Red mode": o5
    };

    L.control.layers(overlays).addTo(map);

    o1.addTo(map);

    map.setMaxBounds(bounds);

    var dotIcon = L.divIcon({className: 'doticon', iconSize: [12, 12]});

    var markers = {};
