jQuery( document ).ready(function() {

    /* Pax modal*/
    var paxcont = jQuery('#peoplecontainer');
    var paxmodal = jQuery('#personcontainer .target');
    var backtoperson = jQuery('.backtoperson');
    var oldtitle = document.title;
    jQuery('.openscheda').on('click', function(e) {
        e.preventDefault();
        paxmodal.text('');
        paxmodal.text('Loading...');
        var _this = jQuery(this);
        var tr = _this.closest('tr');
        var els = tr.find('td');
        paxcont.hide();
        paxmodal.parent().show();
        window.scrollTo(0, 0);
        jQuery.get(_this.data('url'), function(data) {
            var body = '';
            
            body += '<h2 class="mb-0">' + data.nome + ' ' + data.cognome + '</h2>';
            body += '<p class="small mb-2"><em>' + tr.data('cat') + '</em></p>';
            if(data.unimap.ri) {
                body += '<p><small><a href="https://unimap.unipi.it/cercapersone/dettaglio.php?ri=' + data.unimap.ri + '" target="_blank"><i class="fas fa-external-link-alt"></i> Unimap</a></small></p>';
            }
            body += '<table class="table table-sm table-bordered table-striped">';
            els.each(function(i, e) {
                if(i == 2) {
                    body += '<tr><th>Email:</th><td>' + jQuery(this).html() + '</td></tr>';
                } else if(i == 3) {
                    body += '<tr><th>Sito personale:</th><td>' + jQuery(this).html() + '</td></tr>';
                } else if(i == 4) {
                    body += '<tr><th>Stanza:</th><td>' + jQuery(this).html() + '</td></tr>';
                } else if(i == 5) {
                    body += '<tr><th>Telefono:</th><td>' + jQuery(this).html() + '</td></tr>';
                }
            })
            body += '</table>';

            if(data.unimap.arpi)
                body += data.unimap.arpi;
            if(data.unimap.arpilink)
                body += '<p class="small">' + data.unimap.arpilink.replace('</a>', ' <i class="fas fa-external-link-alt"></i></a>') + '</p>';
            if(data.unimap.insegnamenti) {
                body += '<hr />';
                body += data.unimap.insegnamenti;
            }
            if(data.descrizione) {
                body += '<hr />';
                body += data.descrizione;
            }
            paxmodal.html(body);
            window.history.pushState({}, data.nome + ' ' + data.cognome, '#' + _this.data('matricola'));
        });
        return false;
    });
    backtoperson.on('click', function(e) {
        window.scrollTo(0, 0);
        paxmodal.parent().hide();
        paxcont.show();
        window.history.pushState({}, oldtitle, '#');
    });

    var hash = window.location.hash;
    if(hash && jQuery(hash).length) {
        jQuery(hash).find('.openscheda').click();
    }

    jQuery('body').on('click', '.viewmap', function(e) {
      e.preventDefault();
      var _this = jQuery(this);
      map.closePopup();
      map.setView([0,0], 1);
      jQuery('#mapmodal').modal('show');
      toopen = [_this.data('room'), _this.data('pax')];
      return false;
    });

    jQuery('#mapmodal').on('shown.bs.modal', function(){
      setTimeout(function() {
          map.invalidateSize();
          if(toopen.length > 0) {
            markers[toopen[0]].openPopup();
            jQuery('.pax'+toopen[1]).addClass('text-danger');
            toopen = [];
        }
    }, 10);
  });
});

</script>
